# AgentBase production runtime — security posture (MVP checklist §5–6)
# Apply via AgentBase runtime env / secrets — never bake into the Docker image.

APP_ENV=agentbase

# Kill-switch: flip to false to disable chat/sync instantly (health + dashboard stay up).
AGENT_ENABLED=true

# Auto-enabled when APP_ENV=agentbase unless explicitly overridden.
GATEWAY_TRUST_REQUIRED=true

# Prefer HMAC trust in production (store in AgentBase Identity / runtime secret).
GATEWAY_TRUST_SECRET=

# Outbound URLs — TLS enforced at startup (https:// only).
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
CONFLUENCE_BASE_URL=https://yoursite.atlassian.net/wiki

# Platform-injected at deploy time (do not set in image):
# GREENNODE_API_KEY=
# GREENNODE_IDENTITY_URL=
# GREENNODE_MEMORY_URL=
# GREENNODE_AGENT_ID=
