# AgentBase runtime env — pass to runtime.sh as:
#   --env-file deploy/.runtime.env
#
# Copy to deploy/.runtime.env and fill secrets (never commit deploy/.runtime.env).
# Validate before deploy:
#   bash scripts/validate-runtime-env.sh deploy/.runtime.env
#
# DO NOT put these in this file (AgentBase auto-injects at runtime):
#   GREENNODE_CLIENT_ID, GREENNODE_CLIENT_SECRET, GREENNODE_AGENT_IDENTITY,
#   GREENNODE_ENDPOINT_URL, GREENNODE_API_KEY, GREENNODE_IDENTITY_URL,
#   GREENNODE_MEMORY_URL, GREENNODE_AGENT_ID
#
# Operator / CLI only — export in shell or save to .greennode.json for platform API:
#   GREENNODE_CLIENT_ID, GREENNODE_CLIENT_SECRET

APP_ENV=agentbase
LOG_LEVEL=info

# LLM (set LLM_API_KEY or rely on platform GREENNODE_API_KEY fallback)
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=
SMALL_MODEL=
MAIN_MODEL=
EMBEDDING_MODEL=baai/bge-m3

# Confluence — Outbound Auth apikey identity-confluence-zalopay-knowledge
CONFLUENCE_BASE_URL=https://yoursite.atlassian.net/wiki
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_API_KEY_PROVIDER=identity-confluence-zalopay-knowledge
# Confluence space keys — JSON map department_key → space key (see app/common/departments.py).
# Example (keys must match DepartmentKey enum in the registry):
# CONFLUENCE_SPACES={"risk":"ClawathonRisk","grow_enablement":"ClawathonGrow","bank_partnerships":"ClawathonBank"}
CONFLUENCE_SPACES=

# GDrive — Outbound Auth OAuth identity-google-space
GDRIVE_SA_JSON_PATH=
GDRIVE_API_KEY=
GDRIVE_FOLDER_ID=
GDRIVE_OAUTH_PROVIDER=identity-google-space
GDRIVE_OAUTH_SCOPES=https://www.googleapis.com/auth/drive.readonly
GDRIVE_SA_PROVIDER=

INDEX_DIR=/data/index
GRADE_THRESHOLD=0.5
TOPK=8
BRANCH_TIMEOUT_S=20
GRAPH_BUDGET_S=30
LLM_REQUEST_TIMEOUT_S=60
HEALTH_PING_TIMEOUT_S=3
ROUTE_CONFIDENCE_MIN=0.55

# STM — set from /agentbase-memory create
MEMORY_ID=

ROLE_DEPT_ACCESS=

AGENT_ENABLED=true

# PUBLIC MVP (same-origin SPA): false. VPC + gateway: true or omit (defaults true).
GATEWAY_TRUST_REQUIRED=false
GATEWAY_TRUST_SECRET=
