# ─────────────────────────────────────────────────────────────────────────────
# AgentBase operator / CLI credentials — shell export ONLY
#
# Source before agentbase-wizard, deploy skills, or glab/gh automation:
#   set -a && source deploy/operator-cli.env && set +a
#
# NEVER:
#   - add these to AgentBase runtime env / secrets
#   - bake into Docker images
#   - commit filled-in values to git (copy to operator-cli.env locally)
# ─────────────────────────────────────────────────────────────────────────────

# IAM service-account OAuth for AgentBase platform API (wizard, deploy, monitor).
GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=
