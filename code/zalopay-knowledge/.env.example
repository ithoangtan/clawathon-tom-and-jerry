# ─────────────────────────────────────────────────────────────────────────────
# ZaloPay Knowledge Agent — environment configuration
# Copy this file to .env and fill in your values.  Never commit .env.
#
# NOTE: When deploying to GreenNode AgentBase, the GREENNODE_* variables below
# are auto-injected by the platform — do NOT set them locally.  The APP_ENV
# variable controls which adapter wiring is used (local vs agentbase).
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────

# Runtime environment.  Use "local" for docker compose / laptop dev.
# GreenNode AgentBase sets this to "agentbase" automatically at deploy time.
APP_ENV=local

# Docker Compose reads this file via env_file (copy to .env before `make up`).
# For AgentBase deploy images, build with:
#   docker build --platform linux/amd64 -t zalopay-knowledge:test .
# Platform injects GREENNODE_* vars — do not bake secrets into the image.

# Log verbosity: debug | info | warning | error
LOG_LEVEL=info

# ── VNG MaaS LLM (OpenAI-compatible) ─────────────────────────────────────────

# Base URL for the MaaS inference endpoint (VNG HCM cluster default)
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1

# MaaS API key (obtain from VNG Cloud Console → AI Platform → API Keys)
LLM_API_KEY=

# Model IDs for the two tiers.  Ask your VNG MaaS admin for enabled model names.
# Example values (replace with actual enabled model IDs):
#   SMALL_MODEL=qwen2.5-7b-instruct   # used for routing / grading / verify
#   MAIN_MODEL=qwen2.5-72b-instruct   # used for synthesis / reconcile
SMALL_MODEL=
MAIN_MODEL=

# ── Embeddings (local, no MaaS tokens) ───────────────────────────────────────

# HuggingFace model id for local embeddings.
# intfloat/multilingual-e5-small supports Vietnamese + English at 384 dims.
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# ── Confluence Cloud (source: internal KB spaces) ─────────────────────────────

# Your Confluence Cloud base URL, e.g. https://yoursite.atlassian.net/wiki
CONFLUENCE_BASE_URL=

# Atlassian account email used for Basic auth
CONFLUENCE_EMAIL=

# Atlassian API token (generate at https://id.atlassian.com/manage-profile/security/api-tokens)
CONFLUENCE_API_TOKEN=

# Confluence space keys for each of the three departments.
# Find a space key in Confluence: Space Settings → Space Details → Key.
CONFLUENCE_SPACE_RISK=
CONFLUENCE_SPACE_GROW=
CONFLUENCE_SPACE_BANK=

# ── Google Drive (source: PDF documents) ─────────────────────────────────────

# Path to the service-account JSON key file (if using SA auth).
# Mutually exclusive with GDRIVE_API_KEY — SA auth is preferred for production.
GDRIVE_SA_JSON_PATH=

# Google API key (simpler; restricted to read-only Drive scope).
# Only used when GDRIVE_SA_JSON_PATH is not set.
GDRIVE_API_KEY=

# Google Drive folder ID to sync PDFs from.
# Find it in the Drive URL: https://drive.google.com/drive/folders/<FOLDER_ID>
GDRIVE_FOLDER_ID=

# ── Index & retrieval ────────────────────────────────────────────────────────

# Directory where FAISS partitions, SQLite metadata DB, and HF model cache live.
# Docker Compose mounts a named volume at this path (see docker-compose.yml).
# Do NOT change unless you also update docker-compose.yml and the Dockerfile.
INDEX_DIR=/data/index

# HuggingFace / sentence-transformers cache (defaults under INDEX_DIR in Docker).
# HF_HOME=/data/index/hf-cache
# TRANSFORMERS_CACHE=/data/index/hf-cache

# Minimum relevance score (0–1) for a retrieved chunk to pass the grade gate.
# Chunks below this threshold cause a refusal for that department.
GRADE_THRESHOLD=0.5

# Number of chunks to retrieve per department per query (top-k).
TOPK=8

# ── Graph timeouts ────────────────────────────────────────────────────────────

# Per-department subgraph timeout in seconds.  Branches exceeding this are
# marked "timeout" and the reconcile node notes them as partial.
BRANCH_TIMEOUT_S=20

# Global budget for the entire LangGraph execution (seconds).
# The FastAPI handler enforces this as a hard deadline.
GRAPH_BUDGET_S=30

# Minimum routing confidence (0–1).  Below this the router emits a clarifying
# question instead of proceeding directly.
ROUTE_CONFIDENCE_MIN=0.55

# ── Memory (STM, optional) ────────────────────────────────────────────────────

# GreenNode AgentBase Memory ID for short-term memory.
# Leave blank locally — the app falls back to a stateless stub.
# On AgentBase this is auto-set by the platform.
MEMORY_ID=

# ── Access control (FR-7.2) ───────────────────────────────────────────────────

# JSON map of role → allowed department keys.  When unset, the MVP demo default
# grants all departments to engineer/pm/ops/risk roles and excludes "risk" for
# the "business" role (demonstrates S-C1 access denial).
#
# Example — partnerships-only role:
# ROLE_DEPT_ACCESS={"partnerships_only":["bank_partnerships"],"business":["grow_enablement","bank_partnerships"],"engineer":["risk","grow_enablement","bank_partnerships"]}
#
# Valid department keys: risk, grow_enablement, bank_partnerships
ROLE_DEPT_ACCESS=

# ─────────────────────────────────────────────────────────────────────────────
# GreenNode AgentBase injected variables — DO NOT set locally
# These are documented here for reference only; the platform injects them.
# ─────────────────────────────────────────────────────────────────────────────
# GREENNODE_API_KEY=          # injected: MaaS API key override on platform
# GREENNODE_IDENTITY_URL=     # injected: identity service URL
# GREENNODE_MEMORY_URL=       # injected: STM/LTMS service URL
# GREENNODE_AGENT_ID=         # injected: stable agent UUID on platform
