# ─────────────────────────────────────────────────────────────────────────────
# Zalopay Wiki Agent Agent — environment configuration
# Copy this file to .env and fill in your values.  Never commit .env.
#
# NOTE: When deploying to GreenNode AgentBase, the GREENNODE_* variables below
# are auto-injected by the platform — do NOT set them locally.  The APP_ENV
# variable controls which adapter wiring is used (local vs agentbase).
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────

# Runtime environment.  Use "local" for docker compose / laptop dev.
# GreenNode AgentBase sets this to "agentbase" automatically at deploy time.
APP_ENV=local

# Docker Compose reads this file via env_file (copy to .env before `make up`).
# For AgentBase deploy images, build with:
#   docker build --platform linux/amd64 -t zalopay-knowledge:test .
# Platform injects GREENNODE_* vars — do not bake secrets into the image.

# Log verbosity: debug | info | warning | error
LOG_LEVEL=info

# ── VNG MaaS LLM (commented out — switched to OpenAI) ────────────────────────

# LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
# LLM_API_KEY=<vng-maas-key>

# ── OpenAI ────────────────────────────────────────────────────────────────────

# OpenAI API key (local dev).
# On AgentBase: leave blank — key fetched from Identity provider "identity-openai"
#   (Access Control → API Key → provider name: identity-openai).
OPENAI_API_KEY=

# Model IDs (both tiers).
# SMALL_MODEL: routing / grading / claim-verify
# MAIN_MODEL:  synthesis / reconcile
SMALL_MODEL=gpt-5.4-nano
MAIN_MODEL=gpt-5.4-nano

# OpenAI API base URL (default: https://api.openai.com/v1 — no need to set).
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Embeddings ────────────────────────────────────────────────────────────────

# OpenAI embedding model (1536 dims).
# NOTE: khi đổi model thì phải re-index toàn bộ (dim thay đổi từ 1024 → 1536).
EMBEDDING_MODEL=text-embedding-3-large

# ── Confluence Cloud (source: internal KB spaces) ─────────────────────────────

# Confluence Cloud base URL — dạng https://<site>.atlassian.net/wiki
CONFLUENCE_BASE_URL=

# Email Atlassian account của bạn (dùng cho Basic auth)
CONFLUENCE_EMAIL=

# Atlassian API token — lấy từ:
#   https://id.atlassian.com/manage-profile/security/api-tokens → Create API token
# Chỉ dùng cho local dev. Trên AgentBase, token được lưu trong Identity apikey provider.
CONFLUENCE_API_TOKEN=

# AgentBase Outbound Auth → API Key provider name (Access Control console).
CONFLUENCE_API_KEY_PROVIDER=identity-confluence-zalopay-knowledge

# Confluence space keys — JSON map: department_key → Confluence space key.
#
# Tìm space key: Confluence → vào space → Space Settings → Space Details → Key
# Department keys phải khớp với các key trong app/common/departments.py
#
# Ví dụ: CONFLUENCE_SPACES={"risk":"RISK","grow_enablement":"GROW","bank_partnerships":"BANK"}
#
# "workflow" là registry chứa định nghĩa workflow/SOP (non-routable — không phải domain hỏi đáp,
# nhưng vẫn được sync + index để agent tìm và thực thi). Ví dụ kèm workflow:
# CONFLUENCE_SPACES={"risk":"RISK","grow_enablement":"GROW","bank_partnerships":"BANK","workflow":"Workflow"}
#
# Để thêm department mới:
#   1. Đăng ký trong app/common/departments.py
#   2. Thêm entry vào map này
#
# Legacy per-department vars (CONFLUENCE_SPACE_RISK, etc.) vẫn hoạt động khi
# không có trong map này — xem space_env_var trên mỗi Department trong registry.
CONFLUENCE_SPACES=

# ── Google Drive (source: PDF documents) ─────────────────────────────────────

# Local dev only — on AgentBase, store credentials in Identity (see below).
# Path to the service-account JSON key file (if using SA auth).
# Mutually exclusive with GDRIVE_API_KEY — SA auth is preferred for production.
GDRIVE_SA_JSON_PATH=

# Google API key (simpler; restricted to read-only Drive scope).
# Only used when GDRIVE_SA_JSON_PATH is not set.
GDRIVE_API_KEY=

# Google Drive folder ID — lấy từ URL folder trên Drive:
#   https://drive.google.com/drive/folders/<FOLDER_ID>
GDRIVE_FOLDER_ID=

# AgentBase Outbound Auth → OAuth provider (Included Google in Access Control).
# Console name: identity-google-space
GDRIVE_OAUTH_PROVIDER=identity-google-space
GDRIVE_OAUTH_SCOPES=https://www.googleapis.com/auth/drive.readonly

# Optional: apikey provider storing full service-account JSON (leave empty for OAuth-only).
GDRIVE_SA_PROVIDER=

# ── MySQL (Audit + Feedback store) ───────────────────────────────────────────
#
# Production: VDB private endpoint (only reachable inside VPC net192 / 192.168.0.0/24).
# Local dev:  override DB_HOST=127.0.0.1 (or "mysql" in docker-compose).
#
# Lấy username/password từ VDB Console → Relational Database → your instance → Credentials.

DB_HOST=192.168.0.3
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=zalopay_knowledge

# ── Workflow platform (Jira actions) ─────────────────────────────────────────
#
# Jira reuses the Confluence Atlassian credentials above (same site/account) —
# no dedicated JIRA_* vars. Set JIRA_DRY_RUN=true to have workflow `action` steps
# log the intended Jira write without making a network call (safe demos/tests).
JIRA_DRY_RUN=false

# Inbound Jira webhook (POST /webhooks/jira). The Jira Automation rule must send
# this exact value in the `X-Webhook-Secret` header. Empty ⇒ endpoint disabled.
JIRA_WEBHOOK_SECRET=
# accountId the agent posts as (reused Confluence/Jira identity). Events whose
# actor is this account are ignored to avoid feedback loops. Empty ⇒ best-effort.
JIRA_AGENT_ACCOUNT_ID=

# ── Vector store backend ─────────────────────────────────────────────────────
#
# Set to "faiss" for local dev (default) or "opensearch" for AgentBase production.
# When using opensearch, fill in the OPENSEARCH_* variables below.
VECTOR_STORE=faiss

# ── OpenSearch (GreenNode AgentBase managed vector DB) ────────────────────────
#
# Lấy endpoint từ GreenNode console → Vector DB → your instance → Accessibility.
# Credentials từ console → Networking → OpenSearch User section.
# Chỉ cần điền khi VECTOR_STORE=opensearch.
OPENSEARCH_HOST=
OPENSEARCH_PORT=9200
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
# GreenNode dùng self-signed cert — giữ false để bỏ qua certificate verification.
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=false
# Prefix cho tên index: zalopay_risk, zalopay_grow, zalopay_bank
OPENSEARCH_INDEX_PREFIX=zalopay

# ── Index & retrieval ────────────────────────────────────────────────────────

# Directory where FAISS partitions, SQLite metadata DB, and HF model cache live.
#
# Docker (make up):      docker-compose.yml override → /data/index (Docker named volume)
# Local dev (make dev-backend): Makefile override → ./index (thư mục local)
#
# Giá trị dưới đây chỉ áp dụng khi chạy python3 main.py trực tiếp (không qua make).
# Không cần sửa giá trị này trong hầu hết trường hợp.
INDEX_DIR=/data/index

# HuggingFace / sentence-transformers cache (defaults under INDEX_DIR in Docker).
# HF_HOME=/data/index/hf-cache
# TRANSFORMERS_CACHE=/data/index/hf-cache

# Minimum relevance score (0–1) for a retrieved chunk to pass the grade gate.
# Chunks below this threshold cause a refusal for that department.
GRADE_THRESHOLD=0.3

# Number of chunks to retrieve per department per query (top-k).
TOPK=8

# ── Graph timeouts ────────────────────────────────────────────────────────────

# Per-department subgraph timeout in seconds.  Branches exceeding this are
# marked "timeout" and the reconcile node notes them as partial.
BRANCH_TIMEOUT_S=20

# Global budget for the entire LangGraph execution (seconds).
# The FastAPI handler enforces this as a hard deadline.
GRAPH_BUDGET_S=30

# Default timeout for each MaaS chat completion (seconds).
LLM_REQUEST_TIMEOUT_S=60

# MaaS readiness probe timeout used by GET /health/ready (seconds).
HEALTH_PING_TIMEOUT_S=3

# Default timeout for each MaaS chat completion when nodes do not override it.
LLM_REQUEST_TIMEOUT_S=60

# MaaS readiness probe budget for GET /health/ready (models.list ping).
HEALTH_PING_TIMEOUT_S=3

# Minimum routing confidence (0–1).  Below this the router emits a clarifying
# question instead of proceeding directly.
ROUTE_CONFIDENCE_MIN=0.55

# ── Memory (STM, optional) ────────────────────────────────────────────────────

# GreenNode AgentBase Memory ID for short-term memory.
# Leave blank locally — the app falls back to a stateless stub.
# On AgentBase this is auto-set by the platform.
MEMORY_ID=

# Long-term memory strategy ID for user-preference namespace.
# Obtain from Memory store detail page after creating a LTMS (USER_PREFERENCE or CUSTOM type).
# Leave blank to disable LTM recall.
MEMORY_STRATEGY_ID=

# ── Security (MVP checklist §5–6) ─────────────────────────────────────────────

# Kill-switch: set to false to instantly disable chat/sync (health + dashboard stay up).
AGENT_ENABLED=true

# Reject client-supplied X-GreenNode-AgentBase-* identity headers unless the
# trusted gateway adds X-GreenNode-AgentBase-Gateway-Verified: true (or HMAC trust).
# Local dev: keep false (or rely on APP_ENV=local bypass). PUBLIC MVP on AgentBase:
# set false so the SPA can send identity headers on the same origin.
# VPC / gateway-fronted deploys: omit or set true (default when APP_ENV=agentbase).
GATEWAY_TRUST_REQUIRED=false

# Optional HMAC secret for X-GreenNode-AgentBase-Gateway-Trust header.
# When set, gateway must sign user_id:session_id; plain Gateway-Verified is ignored.
GATEWAY_TRUST_SECRET=

HYBRID_SEARCH_ENABLED=false

# ── AgentBase deploy ──────────────────────────────────────────────────────────
#
# File này dùng cho cả local docker-compose và AgentBase deploy.
# AgentBase CLI OAuth (operator only): deploy/operator-cli.env.example → operator-cli.env (shell only)
#
# KHÔNG đặt các biến sau vào AgentBase runtime env (platform reject hoặc tự inject):
#   GREENNODE_CLIENT_ID, GREENNODE_CLIENT_SECRET, GREENNODE_AGENT_IDENTITY
# Xem docs/DEPLOY-READINESS.md để biết full list + validation script.
#
# ── Lưu ý version pinning ─────────────────────────────────────────────────────
#
# requirements.txt pin cứng langgraph==0.2.76 vì greennode-agent-bridge
# được viết cho LangGraph 0.2.x API (JsonPlusSerializer.dumps()).
# LangGraph 0.3+ đã xóa method này gây crash checkpointer trên AgentBase.
# Dockerfile re-pin sau khi install bridge để chặn auto-upgrade.
# KHÔNG bump langgraph cho đến khi bridge được update tương ứng.
